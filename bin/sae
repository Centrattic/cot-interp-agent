#!/usr/bin/env bash
# SAE feature inspection tool — delegates to src/tools/sae.py.
# Requires: SCAFFOLD_ROOT and AGENT_TASK environment variables.

set -euo pipefail

if [[ -z "${SCAFFOLD_ROOT:-}" ]]; then
    echo "Error: SCAFFOLD_ROOT not set. This command must be run inside an agent session."
    exit 1
fi

if [[ "${AGENT_ENABLED_TOOLS+x}" == x && ",${AGENT_ENABLED_TOOLS}," != *",sae,"* ]]; then
    echo "Error: tool 'sae' is not enabled for this run." >&2
    exit 127
fi

PYTHON="${PYTHON:-$(command -v python3 2>/dev/null || command -v python 2>/dev/null)}"
exec "$PYTHON" "$SCAFFOLD_ROOT/src/tools/sae.py" "$@"
