#!/usr/bin/env bash
# Read the logit assigned to a specific token at a specific position.
#
# Usage: logit <example_id> <token_position> <token_to_extract>

set -euo pipefail

if [[ -z "${SCAFFOLD_ROOT:-}" ]]; then
    echo "Error: SCAFFOLD_ROOT not set. This command must be run inside an agent session." >&2
    exit 1
fi

PYTHON="${PYTHON:-$(command -v python3 2>/dev/null || command -v python 2>/dev/null)}"
exec "$PYTHON" "$SCAFFOLD_ROOT/src/tools/logit.py" "$@"
