#!/usr/bin/env bash
# Resample short oracle answers about one example, or validate one follow-up
# question across the labeled few-shot pool.
#
# Usage:
#   sample <example_id> --question "..." [--times N] [--ans LABEL [LABEL ...]]
#   sample --diff --question "..." --ans POS NEG [--times N]

set -euo pipefail

if [[ -z "${SCAFFOLD_ROOT:-}" ]]; then
    echo "Error: SCAFFOLD_ROOT not set. This command must be run inside an agent session." >&2
    exit 1
fi

if [[ -f "$SCAFFOLD_ROOT/.env" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$SCAFFOLD_ROOT/.env"
    set +a
fi

if [[ -n "${AGENT_RUN_DIR:-}" && -f "${AGENT_RUN_DIR}/agent.bashrc" ]]; then
    # shellcheck disable=SC1090
    source "${AGENT_RUN_DIR}/agent.bashrc"
fi

PYTHON="${PYTHON:-$(command -v python3 2>/dev/null || command -v python 2>/dev/null)}"
exec "$PYTHON" "$SCAFFOLD_ROOT/src/tools/sample.py" "$@"
