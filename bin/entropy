#!/usr/bin/env bash
# Entropy of the model's distribution restricted to a set of tokens at a
# given position.
#
# Usage: entropy <example_id> <token_position> <tokens_to_get_entropy_over...>

set -euo pipefail

if [[ -z "${SCAFFOLD_ROOT:-}" ]]; then
    echo "Error: SCAFFOLD_ROOT not set. This command must be run inside an agent session." >&2
    exit 1
fi

PYTHON="${PYTHON:-$(command -v python3 2>/dev/null || command -v python 2>/dev/null)}"
exec "$PYTHON" "$SCAFFOLD_ROOT/src/tools/entropy.py" "$@"
