#!/usr/bin/env bash
# Show the top-10 tokens and their logits at a specific token position,
# read from precomputed logits (see src/precompute_logits.py).
#
# Usage: top_10_logits <example_id> <token_position>

set -euo pipefail

if [[ -z "${SCAFFOLD_ROOT:-}" ]]; then
    echo "Error: SCAFFOLD_ROOT not set. This command must be run inside an agent session." >&2
    exit 1
fi

PYTHON="${PYTHON:-$(command -v python3 2>/dev/null || command -v python 2>/dev/null)}"
exec "$PYTHON" "$SCAFFOLD_ROOT/src/tools/top_10_logits.py" "$@"
